# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend
RESEND_API_KEY=re_your_resend_api_key

# Notification email (receives lead alerts)
NOTIFICATION_EMAIL=you@yourbusiness.com

# Cloudflare Turnstile (spam protection)
# Get keys at: https://dash.cloudflare.com → Turnstile → Add Site
# Test keys (always pass): site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
